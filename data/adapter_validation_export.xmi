<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmlns:uml="http://www.omg.org/spec/UML/20131001" xmlns:xmi="http://www.omg.org/spec/XMI/20131001"><uml:Model xmi:id="satellite-power" name="卫星电源系统 SysML 文档生成示例"><packagedElement xmi:type="uml:Class" xmi:id="REQ-001" name="供电连续性需求" sysmlType="Requirement" stereotype="requirement"><ownedComment body="卫星在任务模式下应保持关键载荷持续供电。" /><taggedValue name="owner" value="总体组" /><taggedValue name="priority" value="High" /><taggedValue name="text" value="在标称日照与地影周期内，电源分系统应向关键载荷提供连续、稳定的 28V 母线供电。" /><taggedValue name="verification" value="Test" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="REQ-002" name="能量余量需求" sysmlType="Requirement" stereotype="requirement"><ownedComment body="系统应具备足够的能量余量以应对负载波动。" /><taggedValue name="owner" value="总体组" /><taggedValue name="priority" value="Medium" /><taggedValue name="text" value="在最大负载工况下，电池荷电状态应保持不低于 30%，且日照段结束时恢复至 85% 以上。" /><taggedValue name="verification" value="Analysis" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="REQ-003" name="故障隔离需求" sysmlType="Requirement" stereotype="requirement"><ownedComment body="单点负载故障不应导致全平台掉电。" /><taggedValue name="owner" value="可靠性组" /><taggedValue name="priority" value="High" /><taggedValue name="text" value="任一非关键负载短路时，配电单元应在 100ms 内完成隔离，并保持关键负载供电。" /><taggedValue name="verification" value="Test" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="REQ-004" name="遥测监控需求" sysmlType="Requirement" stereotype="requirement"><ownedComment body="电源分系统应周期性下传关键状态遥测。" /><taggedValue name="owner" value="总体组" /><taggedValue name="priority" value="Medium" /><taggedValue name="text" value="系统应每 1s 采集并下传母线电压、电池 SOC 和配电通道状态。" /><taggedValue name="verification" value="Inspection" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="BLK-POWER" name="电源分系统" sysmlType="Block" stereotype="block"><ownedComment body="负责太阳能输入调节、电池充放电控制和平台母线供电。" /><taggedValue name="owner" value="电源分系统" /><taggedValue name="mass" value="18 kg" /><taggedValue name="power" value="650 W" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="BLK-SOLAR" name="太阳阵调节器" sysmlType="Block" stereotype="block"><ownedComment body="完成太阳阵最大功率点跟踪和母线能量输入控制。" /><taggedValue name="owner" value="电源分系统" /><taggedValue name="efficiency" value="92%" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="BLK-BATTERY" name="锂离子电池组" sysmlType="Block" stereotype="block"><ownedComment body="在地影期间提供能量，并支持峰值负载削峰。" /><taggedValue name="owner" value="电源分系统" /><taggedValue name="capacity" value="80 Ah" /><taggedValue name="voltage" value="28 V" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="BLK-PDU" name="配电单元" sysmlType="Block" stereotype="block"><ownedComment body="为各载荷和平台设备提供受控配电、保护与故障隔离。" /><taggedValue name="owner" value="电源分系统" /><taggedValue name="channels" value="16" /></packagedElement><packagedElement xmi:type="uml:Port" xmi:id="PRT-28V-BUS" name="28V 母线输出端口" sysmlType="Port" stereotype="proxyPort"><ownedComment body="电源分系统对外提供的受控 28V 供电端口。" /><taggedValue name="owner" value="接口组" /><taggedValue name="direction" value="out" /><taggedValue name="interface" value="IF-POWER-BUS" /><taggedValue name="voltage" value="28 V" /></packagedElement><packagedElement xmi:type="uml:Interface" xmi:id="IF-POWER-BUS" name="平台 28V 电源接口" sysmlType="Interface" stereotype="interfaceBlock"><ownedComment body="定义平台 28V 供电接口的电压、纹波和保护约束。" /><taggedValue name="owner" value="接口组" /><taggedValue name="protocol" value="DC Power" /><taggedValue name="ripple" value="&lt; 100 mV" /><taggedValue name="voltage" value="28 V" /></packagedElement><packagedElement xmi:type="uml:Interface" xmi:id="IF-POWER-TM" name="电源遥测接口" sysmlType="Interface" stereotype="interfaceBlock"><ownedComment body="定义电源分系统向平台数据管理单元上报遥测数据的接口。" /><taggedValue name="owner" value="接口组" /><taggedValue name="cycle" value="1 s" /><taggedValue name="protocol" value="CAN" /></packagedElement><packagedElement xmi:type="uml:Constraint" xmi:id="CST-SOC" name="电池 SOC 约束" sysmlType="Constraint" stereotype="constraintBlock"><ownedComment body="限制地影期间电池荷电状态和日照恢复状态。" /><taggedValue name="owner" value="总体组" /><taggedValue name="expression" value="SOC_min &gt;= 30% and SOC_after_sunlight &gt;= 85%" /></packagedElement><packagedElement xmi:type="uml:Activity" xmi:id="ACT-001" name="进入地影供电流程" sysmlType="Activity" stereotype="activity"><ownedComment body="卫星进入地影后由电池组接管母线供电。" /><taggedValue name="owner" value="电源分系统" /><taggedValue name="result" value="母线电压保持稳定" /><taggedValue name="trigger" value="进入地影" /></packagedElement><packagedElement xmi:type="uml:Activity" xmi:id="ACT-002" name="出地影充电恢复流程" sysmlType="Activity" stereotype="activity"><ownedComment body="卫星出地影后太阳阵恢复供电并为电池充电。" /><taggedValue name="owner" value="电源分系统" /><taggedValue name="result" value="电池 SOC 恢复至目标水平" /><taggedValue name="trigger" value="出地影" /></packagedElement><packagedElement xmi:type="uml:State" xmi:id="ST-SUNLIGHT" name="日照供电状态" sysmlType="State" stereotype="state"><ownedComment body="太阳阵向母线供电并为电池充电。" /><taggedValue name="owner" value="电源分系统" /></packagedElement><packagedElement xmi:type="uml:State" xmi:id="ST-ECLIPSE" name="地影供电状态" sysmlType="State" stereotype="state"><ownedComment body="电池组接管母线供电并维持关键负载。" /><taggedValue name="owner" value="电源分系统" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="TST-001" name="连续供电硬件在环试验" sysmlType="TestCase" stereotype="testCase"><ownedComment body="模拟日照/地影切换，记录母线电压和关键载荷供电状态。" /><taggedValue name="owner" value="验证组" /><taggedValue name="criterion" value="母线电压保持 28V±3%" /><taggedValue name="method" value="HIL Test" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="TST-002" name="能量平衡仿真分析" sysmlType="TestCase" stereotype="testCase"><ownedComment body="基于轨道周期、太阳阵输出和负载剖面进行能量平衡仿真。" /><taggedValue name="owner" value="验证组" /><taggedValue name="criterion" value="SOC 不低于 30%" /><taggedValue name="method" value="Simulation" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="TST-003" name="配电故障注入试验" sysmlType="TestCase" stereotype="testCase"><ownedComment body="注入非关键负载短路故障，验证配电单元隔离时间与供电保持能力。" /><taggedValue name="owner" value="验证组" /><taggedValue name="criterion" value="隔离时间小于 100ms" /><taggedValue name="method" value="Fault Injection" /></packagedElement><packagedElement xmi:type="uml:Class" xmi:id="TST-004" name="遥测接口检查" sysmlType="TestCase" stereotype="testCase"><ownedComment body="检查电源遥测帧字段、周期和接口协议一致性。" /><taggedValue name="owner" value="验证组" /><taggedValue name="criterion" value="遥测周期 1s，字段完整" /><taggedValue name="method" value="Inspection" /></packagedElement><packagedElement xmi:type="uml:Port" xmi:id="PRT-TM-OUT" name="遥测输出端口" sysmlType="Port" stereotype="proxyPort"><ownedComment body="电源分系统向平台数据管理单元输出遥测帧。" /><taggedValue name="owner" value="接口组" /><taggedValue name="direction" value="out" /><taggedValue name="interface" value="IF-POWER-TM" /></packagedElement><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0001" name="satisfy" client="REQ-001" supplier="BLK-POWER" sysmlRelation="satisfy" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0002" name="verify" client="REQ-001" supplier="TST-001" sysmlRelation="verify" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0003" name="satisfy" client="REQ-002" supplier="BLK-BATTERY" sysmlRelation="satisfy" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0004" name="verify" client="REQ-002" supplier="TST-002" sysmlRelation="verify" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0005" name="constrain" client="REQ-002" supplier="CST-SOC" sysmlRelation="constrain" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0006" name="satisfy" client="REQ-003" supplier="BLK-PDU" sysmlRelation="satisfy" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0007" name="verify" client="REQ-003" supplier="TST-003" sysmlRelation="verify" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0008" name="satisfy" client="REQ-004" supplier="IF-POWER-TM" sysmlRelation="satisfy" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0009" name="compose" client="BLK-POWER" supplier="BLK-SOLAR" sysmlRelation="compose" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0010" name="compose" client="BLK-POWER" supplier="BLK-BATTERY" sysmlRelation="compose" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0011" name="compose" client="BLK-POWER" supplier="BLK-PDU" sysmlRelation="compose" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0012" name="expose" client="BLK-POWER" supplier="PRT-28V-BUS" sysmlRelation="expose" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0013" name="connect" client="BLK-POWER" supplier="IF-POWER-TM" sysmlRelation="connect" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0014" name="constrain" client="BLK-POWER" supplier="CST-SOC" sysmlRelation="constrain" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0015" name="connect" client="BLK-PDU" supplier="PRT-28V-BUS" sysmlRelation="connect" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0016" name="connect" client="PRT-28V-BUS" supplier="IF-POWER-BUS" sysmlRelation="connect" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0017" name="constrain" client="CST-SOC" supplier="REQ-002" sysmlRelation="constrain" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0018" name="constrain" client="CST-SOC" supplier="BLK-BATTERY" sysmlRelation="constrain" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0019" name="allocate" client="ACT-001" supplier="BLK-BATTERY" sysmlRelation="allocate" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0020" name="refine" client="ACT-001" supplier="REQ-001" sysmlRelation="refine" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0021" name="flow" client="ACT-001" supplier="ACT-002" sysmlRelation="flow" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0022" name="allocate" client="ACT-002" supplier="BLK-SOLAR" sysmlRelation="allocate" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0023" name="refine" client="ACT-002" supplier="REQ-002" sysmlRelation="refine" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0024" name="transition" client="ST-SUNLIGHT" supplier="ST-ECLIPSE" sysmlRelation="transition" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0025" name="transition" client="ST-ECLIPSE" supplier="ST-SUNLIGHT" sysmlRelation="transition" /><packagedElement xmi:type="uml:Dependency" xmi:id="REL-0026" name="connect" client="PRT-TM-OUT" supplier="IF-POWER-TM" sysmlRelation="connect" /></uml:Model></xmi:XMI>